#!/usr/bin/env python3
"""
vos-factory-run — thin CLI di tracciabilità della fabbrica VOS.
NON decide gate. NON chiama LLM. Solo stato + provenienza.
Compatibile Python 3.8+, macOS 11 Big Sur, stdlib only.
"""

import sys
import os
import json
import shutil
import re
from pathlib import Path
from datetime import datetime, timezone

# Repo root = parent del parent di questo script (bin/../)
REPO_ROOT = Path(__file__).resolve().parents[1]
VENTURES_DIR = REPO_ROOT / "ventures"
KILLED_DIR = REPO_ROOT / "ventures" / "_killed"
TEMPLATE_PATH = REPO_ROOT / "templates" / "venture-dossier.md"
RUNS_LOG = REPO_ROOT / "state" / "factory-runs.jsonl"


def now_iso():
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def make_run_id():
    return "run_" + datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")


def append_log(entry: dict):
    RUNS_LOG.parent.mkdir(parents=True, exist_ok=True)
    with open(RUNS_LOG, "a", encoding="utf-8") as f:
        f.write(json.dumps(entry, ensure_ascii=False) + "\n")


def find_dossier(run_id: str):
    """Cerca il dossier in ventures/<run_id>/ oppure in ventures/_killed/."""
    candidate = VENTURES_DIR / run_id / "venture-dossier.md"
    if candidate.exists():
        return candidate, VENTURES_DIR / run_id
    killed_candidate = KILLED_DIR / run_id / "venture-dossier.md"
    if killed_candidate.exists():
        return killed_candidate, KILLED_DIR / run_id
    return None, None


def read_file(path: Path) -> str:
    with open(path, "r", encoding="utf-8") as f:
        return f.read()


def write_file(path: Path, content: str):
    with open(path, "w", encoding="utf-8") as f:
        f.write(content)


# ---------------------------------------------------------------------------
# FIREWALL: controlla che il blocco provenance della sezione S<n> sia compilato
# (cioè non contenga placeholder {{...}}).
# ---------------------------------------------------------------------------

def check_provenance_compiled(dossier_text: str, section: str) -> bool:
    """
    Cerca il blocco ```yaml ... ``` che contiene 'provenance:' subito dopo
    l'header '## <section>'. Restituisce True se compilato (no {{), False se
    ancora placeholder o blocco assente.
    """
    # Trova l'header della sezione
    header_pattern = re.compile(
        r"^## " + re.escape(section) + r"[ \t]",
        re.MULTILINE
    )
    m = header_pattern.search(dossier_text)
    if not m:
        return False

    # Testo dalla sezione in poi
    section_text = dossier_text[m.start():]

    # Prendi solo fino al prossimo header di livello ## (o fine file)
    next_header = re.search(r"\n## ", section_text[3:])  # skip il ## corrente
    if next_header:
        section_text = section_text[:next_header.start() + 3]

    # Trova il primo blocco ```yaml ... ``` che contiene 'provenance:'
    yaml_blocks = re.findall(r"```yaml(.*?)```", section_text, re.DOTALL)
    for block in yaml_blocks:
        if "provenance:" in block:
            # Se contiene {{ → non compilato
            if "{{" in block:
                return False
            # Se è vuoto o quasi → non compilato
            stripped = block.strip()
            if not stripped or stripped == "provenance:":
                return False
            return True

    # Nessun blocco provenance trovato
    return False


# ---------------------------------------------------------------------------
# COMANDI
# ---------------------------------------------------------------------------

def cmd_init(args):
    if not args:
        print("Uso: vos-factory-run init <seed_envelope.md>", file=sys.stderr)
        sys.exit(1)

    seed_path_raw = args[0]
    seed_path = Path(seed_path_raw).resolve()
    if not seed_path.exists():
        print("Errore: seed_envelope non trovato: {}".format(seed_path), file=sys.stderr)
        sys.exit(1)

    if not TEMPLATE_PATH.exists():
        print("Errore: template non trovato: {}".format(TEMPLATE_PATH), file=sys.stderr)
        sys.exit(1)

    run_id = make_run_id()
    ts = now_iso()
    slug = run_id  # nicchia non nota a S0, uso run_id come slug

    venture_dir = VENTURES_DIR / slug
    venture_dir.mkdir(parents=True, exist_ok=True)

    dossier_dest = venture_dir / "venture-dossier.md"

    # Calcola path relativo dell'envelope rispetto al repo root
    try:
        seed_rel = seed_path.relative_to(REPO_ROOT)
        seed_rel_str = str(seed_rel)
    except ValueError:
        seed_rel_str = str(seed_path)

    # Leggi template e sostituisci i tre placeholder
    template_text = read_file(TEMPLATE_PATH)
    dossier_text = template_text
    dossier_text = dossier_text.replace("{{RUN_ID}}", run_id)
    dossier_text = dossier_text.replace("{{TS}}", ts)
    dossier_text = dossier_text.replace("{{SEED_PATH}}", seed_rel_str)
    # {{seed_envelope path}} nel blocco provenance S0
    dossier_text = dossier_text.replace("{{seed_envelope path}}", seed_rel_str)

    write_file(dossier_dest, dossier_text)

    entry = {
        "ts": ts,
        "run_id": run_id,
        "event": "init",
        "state": "S0",
        "seed_envelope": seed_rel_str,
        "dossier": str(dossier_dest.relative_to(REPO_ROOT))
    }
    append_log(entry)

    print("run_id : {}".format(run_id))
    print("dossier: {}".format(dossier_dest))


def cmd_advance(args):
    # Parse: advance <run_id> --to S<n> --gate <PASS|KILL|REWORK> --evidence <url-or-path>
    if not args:
        print("Uso: vos-factory-run advance <run_id> --to S<n> --gate <PASS|KILL|REWORK> --evidence <url>",
              file=sys.stderr)
        sys.exit(1)

    run_id = args[0]
    rest = args[1:]

    def get_flag(flags, name):
        for i, tok in enumerate(flags):
            if tok == name and i + 1 < len(flags):
                return flags[i + 1]
        return None

    to_state = get_flag(rest, "--to")
    gate = get_flag(rest, "--gate")
    evidence = get_flag(rest, "--evidence")

    if not to_state or not gate or not evidence:
        print("Errore: --to, --gate e --evidence sono obbligatori.", file=sys.stderr)
        sys.exit(1)

    gate = gate.upper()
    if gate not in ("PASS", "KILL", "REWORK"):
        print("Errore: --gate deve essere PASS, KILL o REWORK.", file=sys.stderr)
        sys.exit(1)

    # Valida formato S<n>
    if not re.match(r"^S[0-6]$", to_state):
        print("Errore: --to deve essere S0..S6.", file=sys.stderr)
        sys.exit(1)

    dossier_path, venture_dir = find_dossier(run_id)
    if dossier_path is None:
        print("Errore: run_id non trovato: {}".format(run_id), file=sys.stderr)
        sys.exit(1)

    dossier_text = read_file(dossier_path)

    # FIREWALL: verifica provenance compilata per la sezione target
    if not check_provenance_compiled(dossier_text, to_state):
        print(
            "FIREWALL: provenance mancante per {}, gate non valutabile (firewall).\n"
            "Compila il blocco provenance: della sezione {} nel dossier prima di avanzare.".format(
                to_state, to_state
            ),
            file=sys.stderr
        )
        sys.exit(2)

    ts = now_iso()

    # Aggiorna state: nel front-block YAML del dossier
    # Il front-block è il primo ```yaml ... ``` del file
    def update_yaml_field(text, field, new_value):
        pattern = re.compile(
            r"(^```yaml\s*\n.*?" + re.escape(field) + r":\s*)([^\n]*)",
            re.DOTALL | re.MULTILINE
        )
        return pattern.sub(
            lambda m: m.group(1) + new_value,
            text,
            count=1
        )

    dossier_text = update_yaml_field(dossier_text, "state", to_state)

    # Se KILL con S6 o PASS con n==6: setta verdict: SHIPPED
    sn = int(to_state[1:])
    if gate == "PASS" and sn == 6:
        dossier_text = update_yaml_field(dossier_text, "verdict", "SHIPPED")
    elif gate == "KILL":
        dossier_text = update_yaml_field(dossier_text, "verdict", "KILLED")

    write_file(dossier_path, dossier_text)

    # Se KILL: sposta in _killed/
    if gate == "KILL" and KILLED_DIR.as_posix() not in str(venture_dir):
        KILLED_DIR.mkdir(parents=True, exist_ok=True)
        dest = KILLED_DIR / venture_dir.name
        shutil.move(str(venture_dir), str(dest))
        print("Venture archiviata in: {}".format(dest))

    entry = {
        "ts": ts,
        "run_id": run_id,
        "event": "advance",
        "to_state": to_state,
        "gate": gate,
        "evidence": evidence
    }
    append_log(entry)

    print("OK: {} avanzato a {} (gate={}, evidence={})".format(run_id, to_state, gate, evidence))


def cmd_status(args):
    if not RUNS_LOG.exists():
        print("Nessun run trovato (factory-runs.jsonl assente).")
        return

    # Leggi tutti gli eventi, costruisci stato per run_id
    runs = {}   # run_id -> {state, gate_last, verdict, seed_envelope}
    with open(RUNS_LOG, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                ev = json.loads(line)
            except json.JSONDecodeError:
                continue
            rid = ev.get("run_id", "?")
            if rid not in runs:
                runs[rid] = {"state": "S0", "gate": None, "verdict": None, "seed": ev.get("seed_envelope", "?")}
            if ev.get("event") == "init":
                runs[rid]["state"] = "S0"
                runs[rid]["seed"] = ev.get("seed_envelope", "?")
            elif ev.get("event") == "advance":
                runs[rid]["state"] = ev.get("to_state", runs[rid]["state"])
                runs[rid]["gate"] = ev.get("gate")
                if ev.get("gate") == "PASS" and ev.get("to_state") == "S6":
                    runs[rid]["verdict"] = "SHIPPED"
                elif ev.get("gate") == "KILL":
                    runs[rid]["verdict"] = "KILLED"

    def next_gate(state):
        sn = int(state[1:]) if state and state[1:].isdigit() else 0
        if sn <= 1:
            return "G1 @ S2"
        if sn <= 3:
            return "G2 @ S4"
        if sn <= 5:
            return "G3 @ S6"
        return "completato (S6)"

    if not args:
        # Lista tutti i run
        if not runs:
            print("Nessun run registrato.")
            return
        print("{:<25} {:<6} {:<10} {}".format("run_id", "state", "verdict", "seed"))
        print("-" * 70)
        for rid, info in runs.items():
            print("{:<25} {:<6} {:<10} {}".format(
                rid, info["state"], info["verdict"] or "-", info["seed"]
            ))
    else:
        run_id = args[0]
        if run_id not in runs:
            print("run_id non trovato: {}".format(run_id), file=sys.stderr)
            sys.exit(1)
        info = runs[run_id]
        dossier_path, _ = find_dossier(run_id)
        print("run_id      : {}".format(run_id))
        print("state       : {}".format(info["state"]))
        print("verdict     : {}".format(info["verdict"] or "null"))
        print("seed        : {}".format(info["seed"]))
        print("prossimo    : {}".format(next_gate(info["state"])))
        if dossier_path:
            print("dossier     : {}".format(dossier_path))
        else:
            print("dossier     : non trovato su disco")


# ---------------------------------------------------------------------------
# MAIN
# ---------------------------------------------------------------------------

def main():
    argv = sys.argv[1:]
    if not argv:
        print("Uso: vos-factory-run <init|advance|status> [args...]")
        sys.exit(1)

    cmd = argv[0]
    rest = argv[1:]

    if cmd == "init":
        cmd_init(rest)
    elif cmd == "advance":
        cmd_advance(rest)
    elif cmd == "status":
        cmd_status(rest)
    else:
        print("Comando sconosciuto: {}".format(cmd), file=sys.stderr)
        print("Comandi validi: init, advance, status", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
